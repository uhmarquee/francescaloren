<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FL BASE</title>
  
  <style>
    * {
      box-sizing: border-box;
    }
    body, html {
      margin: 0;
      padding: 0;
      overflow-x: hidden;
    }

    /* ==================== NAVBAR ==================== */
    .navbar {
      background-color: #fff;
      border: 2px solid #000;
      padding: 22px 0;              /* Reduced horizontal padding */
      margin: 10px 20px 15px 20px;  /* Same side margin as image + gap below */
      font-family: Arial, sans-serif;
      max-width: 100%;
    }

    .navbar-inner {
      display: flex;
      align-items: center;
      justify-content: center;
      max-width: 1200px;            /* Controls overall content width */
      margin: 0 auto;
      padding: 0 20px;              /* Inner padding for logo breathing room */
    }

    .logo-link {
      color: #000;
      font-size: 42px;
      font-weight: bold;
      text-decoration: none;
      font-style: italic;
      letter-spacing: 2px;
      white-space: nowrap;
    }

    /* ==================== IMAGE CONTAINER ==================== */
    .image-container-1 {
      width: 100%;
      padding: 0 20px;              /* Same side spacing as navbar */
      margin-top: 0;
    }

    .image-1 {
      width: 100%;
      height: auto;
      object-fit: cover;
      display: block;
      border: 2px solid #000;
    }

    /* ==================== RESPONSIVE ==================== */
    @media screen and (max-width: 768px) {
      .navbar {
        margin: 8px 15px 12px 15px;
      }
      .navbar-inner {
        padding: 0 15px;
      }
      .logo-link {
        font-size: 30px;
      }
      .image-container-1 {
        padding: 0 15px;
      }
    }

    /* Footer */
    footer {
      width: 100%;
      position: static;
    }
    .copyright_text {
      font-size: 20px;
      font-family: Arial, sans-serif;
      text-align: center;
      padding: 25px 0;
    }
  </style>
</head>
<body>

  <!-- Navbar - same width as image -->
  <nav class="navbar">
    <div class="navbar-inner">
      <a href="https://francescaloren.com" class="logo-link">
        <b><i>FRANCESCA LOREN</i></b>
      </a>
    </div>
  </nav>

  <!-- Main Image -->
  <div class="image-container-1">
    <img class="image-1" src="images/image-1.jpg" alt="Francesca Loren">
  </div>

  <footer>
    <div class="copyright_text">2026 FRANCESCA LOREN</div>
  </footer>

</body>
</html>
