<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page.title | default: 'Francesca Loren' }}</title>
  {{ content_for_header }}

  <style>
    * {
      box-sizing: border-box;
    }

    body, html {
      margin: 0;
      padding: 0;
      overflow-x: hidden;
    }

    /* ==================== NAVBAR ==================== */
    .navbar {
      margin-top: 10px;
      background-color: #fff;
      border: 2px solid #000;
      padding: 20px 15px;           /* good padding so text fits inside */
      position: relative;
      z-index: 1001;
      font-family: Arial, sans-serif;
    }

    .navbar-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
    }

    /* Logo - perfectly centered */
    .logo-container {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
    }

    .logo-link {
      color: #000;
      font-size: 32px;
      font-weight: bold;
      text-decoration: none;
      font-style: italic;
      white-space: nowrap;
    }

    /* Nav links */
    .nav-links {
      display: flex;
      gap: 20px;
      list-style: none;
      margin: 0;
      padding: 0;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
    }

    .nav-links a {
      color: #000;
      text-decoration: none;
      font-size: 17px;
      text-transform: uppercase;
      padding: 8px 12px;           /* extra padding so text feels inside the bar */
      white-space: nowrap;
    }

    .nav-links a:hover {
      color: #666;
    }

    /* ==================== IMAGES ==================== */
    .image-container-1 {
      width: 100%;
      position: relative;
      margin-top: 15px;             /* increased gap between navbar and first image */
      padding: 0 10px;
    }

    .image-1 {
      width: 100%;
      height: auto;
      object-fit: cover;
      display: block;
      border: 2px solid #000;
      margin-bottom: 15px;
    }

    /* ==================== RESPONSIVE (Mobile) ==================== */
    @media screen and (max-width: 768px) {
      .navbar {
        padding: 16px 12px;
      }

      .logo-link {
        font-size: 26px;
      }

      .nav-links {
        gap: 12px;
      }

      .nav-links a {
        font-size: 15px;
        padding: 6px 10px;
      }

      .image-container-1 {
        padding: 0 8px;
        margin-top: 12px;
      }

      .image-1 {
        margin-bottom: 12px;
        border-width: 1.5px;
      }
    }

    /* Footer */
    footer {
      width: 100%;
      position: static;
    }

    .copyright_text {
      font-size: 18px;
      font-family: Arial, sans-serif;
      text-align: center;
      padding: 25px 0;
    }
  </style>
</head>
<body>

  {% section 'header' %}

  <!-- Custom Navbar -->
  <nav class="navbar">
    <div class="navbar-inner">
      <!-- Centered Logo -->
      <div class="logo-container">
        <a href="/" class="logo-link">DEADLY DOLL</a>
      </div>

      <!-- Nav Links -->
      <ul class="nav-links">
        <li><a href="/collections/all">Shop</a></li>
        <li><a href="/pages/about">About</a></li>
        <li><a href="/pages/contact">Contact</a></li>
        <!-- Add more links here if needed -->
      </ul>
    </div>
  </nav>

  <main>
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}
  {{ content_for_footer }}

</body>
</html>
