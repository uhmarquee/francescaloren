<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title | default: 'Francesca Loren' }}</title>

  {{ content_for_header }}

  <style>
    /* Your original CSS - cleaned up a bit */
    .navbar {
      margin-top: 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background-color: #fff;
      border: 2px solid #000;
      padding: 30px 20px;
      color: #000;
      font-family: Arial, sans-serif;
      position: relative;
      z-index: 1001;
    }

    .nav-links {
      display: flex;
      gap: 14px;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .nav-links a {
      color: #000;
      text-decoration: none;
      font-size: 20px;
      text-transform: uppercase;
    }

    .nav-links a:hover {
      color: #666;
    }

    .logo-container {
      color: black;
      font-weight: bold;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    .logo-link {
      color: #000;
      font-size: 36px;
      font-weight: bold;
      text-decoration: none;
      font-style: italic;
    }

    .logo-link:hover {
      color: #666;
    }

    .image-container-1 {
      margin-top: 10px;
      height: 4400px; /* ← You said this is too big. We'll reduce it later */
      width: 100%;
      position: relative;
      overflow: visible;
    }

    .image-1 {
      width: 100%;
      height: 36.7%;
      object-fit: cover;
      display: block;
      border: 2px solid black;
    }

    footer {
      width: 100%;
      position: static;
    }

    .copyright_text {
      font-size: 20px;
      font-family: Arial, sans-serif;
      text-align: center;
      padding: 20px 0;
    }
  </style>
</head>
<body>

  {% section 'header' %}
  
  <main>
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {{ content_for_footer }}
</body>
</html>
