<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page.title | default: 'Francesca Loren' }}</title>
  {{ content_for_header }}

  <style>
    /* Basic resets for better mobile behavior */
    * {
      box-sizing: border-box;
    }

    body, html {
      margin: 0;
      padding: 0;
      overflow-x: hidden;
    }

    /* Navbar */
    .navbar {
      margin-top: 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background-color: #fff;
      border: 2px solid #000;
      padding: 20px 15px;
      color: #000;
      font-family: Arial, sans-serif;
      position: relative;
      z-index: 1001;
    }

    .nav-links {
      display: flex;
      gap: 14px;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .nav-links a {
      color: #000;
      text-decoration: none;
      font-size: 18px;
      text-transform: uppercase;
    }

    .logo-container {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    .logo-link {
      color: #000;
      font-size: 32px;
      font-weight: bold;
      text-decoration: none;
      font-style: italic;
    }

    /* Main content container */
    .image-container-1 {
      width: 100%;
      position: relative;
      margin-top: 10px;
      padding: 0 10px;
    }

    /* All images - fixed for mobile */
    .image-1 {
      width: 100%;
      height: auto;
      object-fit: cover;
      display: block;
      border: 2px solid #000;
      margin-bottom: 15px;
    }

    /* Mobile optimizations */
    @media screen and (max-width: 768px) {
      .navbar {
        padding: 18px 12px;
      }
      
      .nav-links a {
        font-size: 16px;
      }
      
      .logo-link {
        font-size: 28px;
      }
      
      .image-container-1 {
        padding: 0 8px;
      }
      
      .image-1 {
        margin-bottom: 12px;
        border-width: 1.5px;
      }
    }

    /* Footer */
    footer {
      width: 100%;
      position: static;
    }

    .copyright_text {
      font-size: 18px;
      font-family: Arial, sans-serif;
      text-align: center;
      padding: 25px 0;
    }
  </style>
</head>
<body>

  {% section 'header' %}

  <main>
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}
  {{ content_for_footer }}

</body>
</html>
