<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page.title | default: 'Francesca Loren' }}</title>
  {{ content_for_header }}

  <style>
    * {
      box-sizing: border-box;
    }

    body, html {
      margin: 0;
      padding: 0;
      overflow-x: hidden;
    }

    /* ==================== IMAGES ==================== */
    .image-container-1 {
      width: 100%;
      position: relative;
      margin-top: 0;           /* removed extra gap since navbar is gone */
      padding: 0 10px;
    }

    .image-1 {
      width: 100%;
      height: auto;
      object-fit: cover;
      display: block;
      border: 2px solid #000;
      margin-bottom: 15px;
    }

    /* ==================== RESPONSIVE (Mobile) ==================== */
    @media screen and (max-width: 768px) {
      .image-container-1 {
        padding: 0 8px;
      }

      .image-1 {
        margin-bottom: 12px;
        border-width: 1.5px;
      }
    }

    /* Footer */
    footer {
      width: 100%;
      position: static;
    }

    .copyright_text {
      font-size: 18px;
      font-family: Arial, sans-serif;
      text-align: center;
      padding: 25px 0;
    }
  </style>
</head>
<body>

  {% section 'header' %}

  <main>
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}
  {{ content_for_footer }}

</body>
</html>
