<style>
  .sticky-note {
    position: fixed;
    top: 120px;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 400px;
    background: #fff59d;
    border: 3px solid #e0c040;
    box-shadow: 8px 8px 25px rgba(0, 0, 0, 0.5);
    z-index: 9999;
    overflow: hidden;
  }

  .title-bar {
    background: linear-gradient(to right, #000080, #1084d0);
    color: white;
    padding: 6px 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: move;
    user-select: none;
    height: 32px;
  }

  .buttons { display: flex; gap: 4px; }

  .btn {
    width: 24px;
    height: 22px;
    background: #c0c0c0;
    border: 1px solid #dfdfdf;
    border-right-color: #808080;
    border-bottom-color: #808080;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .close-btn:hover { background: #e51400; color: white; }

  .stickynote-content {
    height: calc(100% - 32px);
    padding: 15px;
    background: #fff59d;
  }

  .stickynote-content textarea {
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
    outline: none;
    font-size: 16px;
    line-height: 1.5;
    resize: none;
    font-family: Arial, sans-serif;
  }
</style>

<body>
<!-- STICKY NOTE -->
<div class="sticky-note" id="stickyWindow">
  <div class="title-bar" id="titleBar">
    <span class="title">Sticky Note</span>
    <div class="buttons">
      <button class="btn" id="minBtn">_</button>
      <button class="btn" id="maxBtn">□</button>
      <button class="btn close-btn" id="closeBtn">✕</button>
    </div>
  </div>
  <div class="stickynote-content" id="contentArea">
    <textarea id="noteText">Hi, my nickname is Harle nice to meet ya! Sorry, I'm busy right now, but I'll see ya soon!
-HQ</textarea>
  </div>
</div>
</body>



