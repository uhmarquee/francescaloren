<!-- SIMPLE STICKY NOTE - FOR TESTING -->

<div class="sticky-note" id="stickyWindow" style="display: block !important;">
  <div style="background: linear-gradient(to right, #000080, #1084d0); color: white; padding: 8px 12px; display: flex; justify-content: space-between; align-items: center;">
    <span style="font-weight: bold;">Sticky Note</span>
    <button id="closeBtn" style="background: #e51400; color: white; border: none; width: 24px; height: 24px; cursor: pointer;">✕</button>
  </div>
  <div style="background: #fff59d; padding: 15px; min-height: 300px;">
    <textarea style="width: 100%; height: 280px; border: none; outline: none; font-size: 16px; resize: none; background: transparent;">Hi, my nickname is Harle nice to meet ya! Sorry, I'm busy right now, but I'll see ya soon!
-HQ</textarea>
  </div>
</div>

<style>
  .sticky-note {
    position: fixed !important;
    top: 4600px !important;     /* Adjust this number */
    left: 50% !important;
    transform: translateX(-50%) !important;
    width: 500px;
    max-width: 92vw;
    z-index: 99999 !important;
    box-shadow: 0 10px 30px rgba(0,0,0,0.6);
    border: 3px solid #e0c040;
  }
</style>

<script>
  document.getElementById('closeBtn').addEventListener('click', function() {
    document.getElementById('stickyWindow').style.display = 'none';
  });
</script>
