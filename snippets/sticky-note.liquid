<!-- =============== STICKY NOTE =============== -->
<div class="sticky-note" id="stickyWindow">
  <div class="title-bar" id="titleBar">
    <span class="title">Sticky Note</span>
    <div class="buttons">
      <button class="btn" id="minBtn">_</button>
      <button class="btn" id="maxBtn">□</button>
      <button class="btn close-btn" id="closeBtn">✕</button>
    </div>
  </div>
  <div class="stickynote-content" id="contentArea">
    <textarea id="noteText">Hi, my nickname is Harle nice to meet ya! Sorry, I'm busy right now, but I'll see ya soon!
-HQ</textarea>
  </div>
</div>

<style>
  /* ==================== OVERALL PAGE WIDTH ==================== */
  body {
    max-width: 5000px;
    margin: 0 auto;
    background-color: #fff;
  }

  .sticky-note {
    position: absolute;           /* Keep absolute for desktop as you like it */
    top: 1200px;
    margin-top: 900px;
    left: 50%;
    transform: translateX(-211%);   /* Fixed the weird -211% */
    width: 700px;
    max-width: 92vw;
    height: 600px;
    background: #fff59d;
    border: 3px solid #e0c040;
    box-shadow: 8px 8px 25px rgba(0, 0, 0, 0.5);
    z-index: 9999;
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .title-bar {
    background: linear-gradient(to right, #000080, #1084d0);
    color: white;
    padding: 6px 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: move;
    user-select: none;
    height: 32px;
  }

  .title { font-weight: bold; font-size: 14px; }
  .buttons { display: flex; gap: 4px; }

  .btn {
    width: 24px;
    height: 22px;
    background: #c0c0c0;
    border: 1px solid #dfdfdf;
    border-right-color: #808080;
    border-bottom-color: #808080;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .close-btn:hover {
    background: #e51400;
    color: white;
  }

  .stickynote-content {
    height: calc(100% - 32px);
    padding: 15px;
    background: #fff59d;
  }

  .stickynote-content textarea {
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
    outline: none;
    font-size: 15.5px;
    line-height: 1.5;
    resize: none;
    font-family: Arial, sans-serif;
  }
/* Sticky Note Window Behavior - matching your image containers */
.minimized {
    height: 32px !important;
}

.minimized .stickynote-content {
    display: none;
}

.enlarged {
    width: 85vw !important;
    height: 520px !important;     /* Desktop enlarged size */
    z-index: 99999 !important;
}

/* Mobile enlarged size */
@media screen and (max-width: 768px) {
    .enlarged {
        width: 92vw !important;
        height: 420px !important;
    }
}
  /* ================= RESPONSIVE SIZES ================= */
/* Tablets */
  @media screen and (max-width: 1024px) {
    .sticky-note {
      width: 460px;
      height: 380px;
    }
  }


  /* Mobile phones - FORCE it to show */
  @media screen and (max-width: 1500px) {
    .sticky-note {
      position: absolute !important;     /* Most important change */
      top: 900px !important;          /* Adjust this number if needed (higher = lower on screen) */
      left: 50% !important;
      transform: translateX(-80%) !important;
      margin-top: 650px !important;
      width: 60vw;
      height: 280px;
      z-index: 99999;
    }
  }

/* Very small phones */
  @media screen and (max-width: 480px) {
    .sticky-note {
      top: 70px !important;
      height: 280px;
    }
    .stickynote-content textarea {
      font-size: 14.5px;
    }
  }
</style>

<script>
'use strict';

document.addEventListener('DOMContentLoaded', function() {
    const stickyWindow = document.getElementById('stickyWindow');
    const minBtn = document.getElementById('minBtn');
    const maxBtn = document.getElementById('maxBtn');
    const closeBtn = document.getElementById('closeBtn');

    // State tracking (same pattern as your image containers)
    const stickyState = {
        isMinimized: false,
        isEnlarged: false,
        originalWidth: '',
        originalHeight: '',
        originalTop: '',
        originalLeft: ''
    };

    function saveOriginalState() {
        stickyState.originalWidth = stickyWindow.style.width || getComputedStyle(stickyWindow).width;
        stickyState.originalHeight = stickyWindow.style.height || getComputedStyle(stickyWindow).height;
        stickyState.originalTop = stickyWindow.style.top;
        stickyState.originalLeft = stickyWindow.style.left;
    }

    // Minimize (same as your other containers)
    minBtn.addEventListener('click', function() {
        if (stickyState.isMinimized) {
            stickyWindow.classList.remove('minimized');
            stickyState.isMinimized = false;
        } else {
            stickyWindow.classList.add('minimized');
            stickyState.isMinimized = true;
        }
    });

    // Maximize / Restore (in-place, no jumping)
    maxBtn.addEventListener('click', function() {
        if (stickyState.isEnlarged) {
            // Restore
            stickyWindow.style.width = stickyState.originalWidth;
            stickyWindow.style.height = stickyState.originalHeight;
            stickyWindow.style.top = stickyState.originalTop;
            stickyWindow.style.left = stickyState.originalLeft;
            stickyWindow.classList.remove('enlarged');
            maxBtn.textContent = '□';
            stickyState.isEnlarged = false;
        } else {
            // Save current state first
            saveOriginalState();
            
            // Enlarge without moving position
            stickyWindow.classList.add('enlarged');
            maxBtn.textContent = '❐';
            stickyState.isEnlarged = true;
        }
    });

    // Close
    closeBtn.addEventListener('click', function() {
        stickyWindow.style.display = 'none';
    });

    // Initial save
    saveOriginalState();
});
</script>
