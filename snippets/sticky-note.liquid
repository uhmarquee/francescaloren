<!-- =============== STICKY NOTE =============== -->
<div class="sticky-note" id="stickyWindow">
  <div class="title-bar" id="titleBar">
    <span class="title">Sticky Note</span>
    <div class="buttons">
      <button class="btn" id="minBtn">_</button>
      <button class="btn" id="maxBtn">□</button>
      <button class="btn close-btn" id="closeBtn">✕</button>
    </div>
  </div>
  <div class="stickynote-content" id="contentArea">
    <textarea id="noteText">Hi, my nickname is Harle nice to meet ya! Sorry, I'm busy right now, but I'll see ya soon!
-HQ</textarea>
  </div>
</div>

<style>
  body {
    max-width: 5000px;
    margin: 0 auto;
    background-color: #fff;
  }

  .sticky-note {
    position: absolute;
    top: 1200px;
    margin-top: 900px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    max-width: 92vw;
    height: 600px;
    background: #fff59d;
    border: 3px solid #e0c040;
    box-shadow: 8px 8px 25px rgba(0, 0, 0, 0.5);
    z-index: 9999;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .title-bar {
    background: linear-gradient(to right, #000080, #1084d0);
    color: white;
    padding: 6px 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: move;
    user-select: none;
    height: 32px;
  }

  .title { font-weight: bold; font-size: 14px; }
  .buttons { display: flex; gap: 4px; }

  .btn {
    width: 24px;
    height: 22px;
    background: #c0c0c0;
    border: 1px solid #dfdfdf;
    border-right-color: #808080;
    border-bottom-color: #808080;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .close-btn:hover { background: #e51400; color: white; }

  .stickynote-content {
    height: calc(100% - 32px);
    padding: 15px;
    background: #fff59d;
  }

  .stickynote-content textarea {
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
    outline: none;
    font-size: 15.5px;
    line-height: 1.5;
    resize: none;
    font-family: Arial, sans-serif;
  }

  /* ================= RESPONSIVE SIZES ================= */
  @media screen and (max-width: 1024px) {
    .sticky-note {
      width: 460px;
      height: 380px;
    }
  }

  @media screen and (max-width: 768px) {
    .sticky-note {
      position: fixed !important;
      top: 120px !important;
      left: 50% !important;
      transform: translateX(-50%) !important;
      margin-top: 0 !important;
      width: 88vw;
      height: 300px;
    }
  }

  @media screen and (max-width: 480px) {
    .sticky-note {
      height: 260px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const stickyWindow = document.getElementById('stickyWindow');
    const titleBar = document.getElementById('titleBar');
    const minBtn = document.getElementById('minBtn');
    const maxBtn = document.getElementById('maxBtn');
    const closeBtn = document.getElementById('closeBtn');
    const contentArea = document.getElementById('contentArea');

    let isMaximized = false;
    let isDragging = false;
    let offsetX, offsetY;
    let originalStyles = {};

    function saveOriginalStyles() {
      originalStyles = {
        width: stickyWindow.style.width,
        height: stickyWindow.style.height,
        top: stickyWindow.style.top,
        left: stickyWindow.style.left,
        transform: stickyWindow.style.transform,
        marginTop: stickyWindow.style.marginTop
      };
    }

    // Dragging (mouse + touch)
    function startDrag(e) {
      if (e.target.tagName === 'BUTTON') return;
      isDragging = true;
      const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
      const clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
      offsetX = clientX - stickyWindow.offsetLeft;
      offsetY = clientY - stickyWindow.offsetTop;
      stickyWindow.style.transform = 'none';
    }

    function drag(e) {
      if (!isDragging) return;
      const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
      const clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
      stickyWindow.style.left = (clientX - offsetX) + 'px';
      stickyWindow.style.top = (clientY - offsetY) + 'px';
    }

    titleBar.addEventListener('mousedown', startDrag);
    document.addEventListener('mousemove', drag);
    document.addEventListener('mouseup', () => isDragging = false);
    titleBar.addEventListener('touchstart', startDrag, { passive: true });
    document.addEventListener('touchmove', drag, { passive: true });
    document.addEventListener('touchend', () => isDragging = false);

    minBtn.addEventListener('click', () => {
      contentArea.style.display = 'none';
      stickyWindow.style.height = '32px';
    });

    maxBtn.addEventListener('click', () => {
      if (!isMaximized) {
        saveOriginalStyles();
        
        // Resize without moving position
        stickyWindow.style.width = '85vw';
        stickyWindow.style.height = '520px';           // Desktop big size
        maxBtn.textContent = '❐';
        isMaximized = true;
      } else {
        // Restore original position and size
        stickyWindow.style.width = originalStyles.width || '';
        stickyWindow.style.height = originalStyles.height || '';
        stickyWindow.style.top = originalStyles.top || '';
        stickyWindow.style.left = originalStyles.left || '';
        stickyWindow.style.transform = originalStyles.transform || '';
        stickyWindow.style.marginTop = originalStyles.marginTop || '';
        
        maxBtn.textContent = '□';
        isMaximized = false;
      }
      contentArea.style.display = 'block';
    });

    closeBtn.addEventListener('click', () => {
      stickyWindow.style.display = 'none';
    });

    saveOriginalStyles();
  });
</script>
