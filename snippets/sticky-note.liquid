<!-- =============== STICKY NOTE =============== -->
<div class="sticky-note" id="stickyWindow">
  <div class="title-bar" id="titleBar">
    <span class="title">Sticky Note</span>
    <div class="buttons">
      <button class="btn" id="minBtn">_</button>
      <button class="btn" id="maxBtn">□</button>
      <button class="btn close-btn" id="closeBtn">✕</button>
    </div>
  </div>
  <div class="stickynote-content" id="contentArea">
    <textarea id="noteText">Hi, my nickname is Harle nice to meet ya! Sorry, I'm busy right now, but I'll see ya soon!
-HQ</textarea>
  </div>
</div>

<style>
  /* ==================== OVERALL PAGE WIDTH ==================== */
  body {
    max-width: 5000px;
    margin: 0 auto;
    background-color: #fff;
  }

  .sticky-note {
    position: absolute;
    top: 1200px;
    margin-top: 900px;
    margin-bottom: 100px;
    left: 50%;
    transform: translateX(-240%);
    width: 700px;
    max-width: 92vw;
    height: 600px;
    background: #fff59d;
    border: 3px solid #e0c040;
    box-shadow: 8px 8px 25px rgba(0, 0, 0, 0.5);
    z-index: 9999;
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .title-bar {
    background: linear-gradient(to right, #000080, #1084d0);
    color: white;
    padding: 6px 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: move;
    user-select: none;
    height: 32px;
  }

  .title { font-weight: bold; font-size: 14px; }
  .buttons { display: flex; gap: 4px; }

  .btn {
    width: 24px;
    height: 22px;
    background: #c0c0c0;
    border: 1px solid #dfdfdf;
    border-right-color: #808080;
    border-bottom-color: #808080;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .close-btn:hover { 
    background: #e51400; 
    color: white; 
  }

  .stickynote-content {
    height: calc(100% - 32px);
    padding: 15px;
    background: #fff59d;
  }

  .stickynote-content textarea {
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
    outline: none;
    font-size: 15.5px;
    line-height: 1.5;
    resize: none;
    font-family: Arial, sans-serif;
  }


/* ================= RESPONSIVE SIZES ================= */

/* Tablets */
@media screen and (max-width: 1024px) {
  .sticky-note {
    width: 460px;
    height: 380px;
  }
}

/* Mobile phones */
@media screen and (max-width: 768px) {
  .sticky-note {
    top: 80px;
    width: 88vw;
    height: 300px;
  }
}

/* Very small phones */
@media screen and (max-width: 480px) {
  .sticky-note {
    height: 270px;
  }
  .stickynote-content textarea {
    font-size: 14.5px;
  }
}

</style>







<script>
  document.addEventListener('DOMContentLoaded', function() {
    const stickyWindow = document.getElementById('stickyWindow');
    const titleBar = document.getElementById('titleBar');
    const minBtn = document.getElementById('minBtn');
    const maxBtn = document.getElementById('maxBtn');
    const closeBtn = document.getElementById('closeBtn');
    const contentArea = document.getElementById('contentArea');

    let isMaximized = false;
    let isDragging = false;
    let offsetX, offsetY;
    let originalStyles = {};   // Store original size/position

    // Save original styles on load
    function saveOriginalStyles() {
      originalStyles = {
        width: stickyWindow.style.width,
        height: stickyWindow.style.height,
        top: stickyWindow.style.top,
        left: stickyWindow.style.left,
        transform: stickyWindow.style.transform
      };
    }

    titleBar.addEventListener('mousedown', (e) => {
      if (e.target.tagName === 'BUTTON') return;
      isDragging = true;
      offsetX = e.clientX - stickyWindow.offsetLeft;
      offsetY = e.clientY - stickyWindow.offsetTop;
      stickyWindow.style.transform = 'none';
    });

    document.addEventListener('mousemove', (e) => {
      if (isDragging) {
        stickyWindow.style.left = (e.clientX - offsetX) + 'px';
        stickyWindow.style.top = (e.clientY - offsetY) + 'px';
      }
    });

    document.addEventListener('mouseup', () => isDragging = false);

    minBtn.addEventListener('click', () => {
      contentArea.style.display = 'none';
      stickyWindow.style.height = '32px';
    });

    maxBtn.addEventListener('click', () => {
      if (!isMaximized) {
        // Save current state before maximizing
        saveOriginalStyles();

        stickyWindow.style.width = '90vw';
        stickyWindow.style.height = '75vh';
        stickyWindow.style.top = '10vh';
        stickyWindow.style.left = '5vw';
        stickyWindow.style.transform = 'none';
        maxBtn.textContent = '❐';
        isMaximized = true;
      } else {
        // Restore to original (responsive) size
        stickyWindow.style.width = originalStyles.width || '';
        stickyWindow.style.height = originalStyles.height || '';
        stickyWindow.style.top = originalStyles.top || '';
        stickyWindow.style.left = originalStyles.left || '';
        stickyWindow.style.transform = originalStyles.transform || 'translateX(-50%)';
        
        maxBtn.textContent = '□';
        isMaximized = false;
      }
      contentArea.style.display = 'block';
    });

    closeBtn.addEventListener('click', () => {
      stickyWindow.style.display = 'none';
    });

    // Save original styles after everything loads
    saveOriginalStyles();
  });
</script>
